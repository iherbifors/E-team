// ───────────────────────────────────────────────────────────────
//  1) 중위 → 후위 변환 클래스
//  예: "3+4*2" → "3 4 2 * +"
// ───────────────────────────────────────────────────────────────
class Infix2Postfix {

    /**
     * 중위 표현식(Infix)을 후위 표현식(Postfix)으로 변환한다.
     * 지원 연산자: + - * / % ( )
     *
     * @param exp 중위 표현식 문자열
     * @return 후위 표현식 문자열 (공백 구분), 입력이 없으면 null
     */
    public static String convert(String exp) {
        if (exp == null || exp.length() == 0) return null;

        // % 를 구분자에 포함 → % 도 연산자로 토큰 분리
        StringTokenizer st = new StringTokenizer(exp, "+-*/%()", true);
        Stack<String> stack = new Stack<>();  // 연산자를 임시 저장하는 스택
        StringBuffer buf = new StringBuffer(); // 후위 표현식을 쌓을 버퍼

        while (st.hasMoreTokens()) {
            String tok = st.nextToken().trim(); // 앞뒤 공백 제거
            if (tok.length() == 0) continue;

            // ── 음수 처리 ─────────────────────────────────────
            // 수식 시작, '(' 직후, 연산자 직후에 오는 '-' 는 음수 부호로 처리
            if (tok.equals("-")) {
                boolean isUnary = buf.length() == 0                         // 수식 맨 앞
                    || buf.toString().endsWith("( ")                        // '(' 바로 뒤
                    || (buf.length() > 0 && opType(buf.substring(buf.length() - 2).trim()) > 0); // 연산자 뒤

                if (isUnary) {
                    String next = st.nextToken().trim(); // 음수 부호 뒤의 숫자
                    buf.append("-").append(next).append(" "); // "-숫자" 형태로 후위에 직접 추가
                    continue;
                }
            }

            // ── 여는 괄호: 스택에 push ────────────────────────
            if (tok.equals("(")) {
                stack.push(tok);
            }
            // ── 닫는 괄호: '(' 나올 때까지 스택 pop ──────────
            else if (tok.equals(")")) {
                while (!stack.isEmpty() && !stack.peek().equals("("))
                    buf.append(stack.pop()).append(" ");
                if (!stack.isEmpty()) stack.pop(); // '(' 제거
            }
            // ── 연산자: 우선순위 비교 후 처리 ────────────────
            else if (opType(tok) > 0) {
                // 스택 top의 우선순위가 현재 연산자 이상이면 먼저 pop
                while (!stack.isEmpty()) {
                    if (stack.peek().equals("(")) break;
                    int p1 = getPriority(tok.charAt(0));        // 현재 연산자 우선순위
                    int p2 = getPriority(stack.peek().charAt(0)); // 스택 top 우선순위
                    if (p1 <= p2) buf.append(stack.pop()).append(" ");
                    else break;
                }
                stack.push(tok); // 현재 연산자를 스택에 push
            }
            // ── 숫자(피연산자): 후위 버퍼에 바로 추가 ────────
            else {
                buf.append(tok).append(" ");
            }
        }

        // 스택에 남은 연산자 모두 후위 버퍼에 추가
        while (!stack.isEmpty())
            buf.append(stack.pop()).append(" ");

        return buf.toString();
    }

    /**
     * 문자열이 연산자인지 확인한다.
     * +,-,*,/,% → 양수(종류 번호) 반환 / 아니면 -1
     */
    public static int opType(String op) {
        op = op.trim();
        if (op.length() > 1 || op.length() == 0) return -1;
        switch (op.charAt(0)) {
            case '+': return 1;
            case '-': return 2;
            case '*': return 3;
            case '/': return 4;
            case '%': return 5; // % 연산자 추가
        }
        return -1;
    }

    /**
     * 연산자의 우선순위를 반환한다.
     * % 는 * / 와 동일한 우선순위(2)로 설정
     */
    private static int getPriority(char op) {
        switch (op) {
            case '+': case '-': return 1;           // 덧셈/뺄셈: 낮은 우선순위
            case '*': case '/': case '%': return 2; // 곱셈/나눗셈/나머지: 높은 우선순위
            default: return -1;
        }
    }
}


// ───────────────────────────────────────────────────────────────
//  2) 후위 표현식 계산 클래스
//  스택을 이용해 후위 표현식을 계산한다.
// ───────────────────────────────────────────────────────────────
class Calc {

    /**
     * 후위 표현식을 계산하여 double 결과를 반환한다.
     * 지원 연산자: + - * / %
     *
     * @param postfix 후위 표현식 (공백으로 토큰 구분)
     * @return 계산 결과
     * @throws ArithmeticException      0으로 나누기/나머지 연산 시
     * @throws IllegalArgumentException 잘못된 수식 형식일 때
     */
    public static double eval(String postfix) {
        if (postfix == null || postfix.trim().isEmpty())
            throw new IllegalArgumentException("수식이 비어 있습니다.");

        Stack<Double> stack = new Stack<>(); // 피연산자를 저장하는 스택
        StringTokenizer st = new StringTokenizer(postfix, " ");

        while (st.hasMoreTokens()) {
            String tok = st.nextToken().trim();
            if (tok.isEmpty()) continue;

            // ── 연산자: 스택에서 피연산자 2개 꺼내 계산 ──────
            if (isOperator(tok)) {
                if (stack.size() < 2)
                    throw new IllegalArgumentException("잘못된 수식입니다.");

                double b = stack.pop(); // 오른쪽 피연산자 (나중에 push된 것)
                double a = stack.pop(); // 왼쪽 피연산자 (먼저 push된 것)
                double result;

                switch (tok.charAt(0)) {
                    case '+': result = a + b; break;
                    case '-': result = a - b; break;
                    case '*': result = a * b; break;
                    case '/':
                        // 0으로 나누기 방지
                        if (b == 0) throw new ArithmeticException("0으로 나눌 수 없습니다.");
                        result = a / b; break;
                    case '%':
                        // 나머지 연산 추가 (% 지원)
                        if (b == 0) throw new ArithmeticException("0으로 나머지 연산 불가.");
                        result = a % b; break;
                    default:
                        throw new IllegalArgumentException("알 수 없는 연산자: " + tok);
                }
                stack.push(result); // 계산 결과를 다시 스택에 push

            }
            // ── 숫자: 스택에 push ─────────────────────────────
            else {
                try {
                    stack.push(Double.parseDouble(tok));
                } catch (NumberFormatException e) {
                    throw new IllegalArgumentException("숫자 변환 오류: " + tok);
                }
            }
        }

        // 정상적인 수식이면 스택에 결과 하나만 남음
        if (stack.size() != 1)
            throw new IllegalArgumentException("잘못된 수식입니다.");

        return stack.pop();
    }

    /**
     * 토큰이 연산자(+,-,*,/,%)인지 확인한다.
     */
    private static boolean isOperator(String tok) {
        return tok.length() == 1 && "+-*/%".indexOf(tok.charAt(0)) >= 0;
    }
}


// ───────────────────────────────────────────────────────────────
//  3) 둥근 모서리 버튼 UI 커스텀 클래스
//  Java 기본 버튼 대신 직접 그려서 둥근 사각형 + 호버/클릭 효과 구현
// ───────────────────────────────────────────────────────────────
class RoundButtonUI extends javax.swing.plaf.basic.BasicButtonUI {

    private final Color baseColor;  // 버튼 기본 배경색
    private final Color textColor;  // 버튼 글자 색

    /**
     * @param base 버튼 배경색
     * @param text 글자 색 (핑크)
     */
    public RoundButtonUI(Color base, Color text) {
        this.baseColor = base;
        this.textColor = text;
    }

    @Override
    public void installUI(JComponent c) {
        super.installUI(c);
        // 기본 버튼 장식 모두 제거 (직접 그릴 것이므로)
        JButton btn = (JButton) c;
        btn.setOpaque(false);         // 배경을 직접 그리므로 false
        btn.setFocusPainted(false);   // 포커스 테두리 제거
        btn.setBorderPainted(false);  // 기본 테두리 제거
        btn.setContentAreaFilled(false); // 기본 채우기 제거
    }

    @Override
    public void paint(Graphics g, JComponent c) {
        JButton btn = (JButton) c;
        Graphics2D g2 = (Graphics2D) g.create();

        // 안티앨리어싱 ON → 둥근 모서리가 부드럽게 렌더링됨
        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
        g2.setRenderingHint(RenderingHints.KEY_TEXT_ANTIALIASING, RenderingHints.VALUE_TEXT_ANTIALIAS_ON);

        int w = c.getWidth();
        int h = c.getHeight();
        int arc = 14; // 모서리 둥글기 반지름 (클수록 더 둥글게)

        boolean pressed  = btn.getModel().isPressed();  // 클릭 중 여부
        boolean hovered  = btn.getModel().isRollover(); // 마우스 올라간 여부

        // ── 버튼 배경 그리기 ──────────────────────────────────
        if (pressed) {
            // 눌렸을 때: 더 밝게 (밝은 회색)
            g2.setColor(baseColor.brighter());
        } else if (hovered) {
            // 마우스 올라갔을 때: 약간 밝게
            g2.setColor(baseColor.brighter().brighter());
        } else {
            // 기본 상태
            g2.setColor(baseColor);
        }
        // 둥근 사각형으로 버튼 배경 채우기
        g2.fillRoundRect(1, 1, w - 2, h - 2, arc, arc);

        // ── 버튼 테두리 (살짝 밝은 선) ───────────────────────
        g2.setColor(new Color(80, 80, 85)); // 테두리색: 배경보다 약간 밝은 회색
        g2.drawRoundRect(1, 1, w - 2, h - 2, arc, arc);

        // ── 텍스트 중앙 정렬해서 그리기 ──────────────────────
        g2.setFont(btn.getFont());
        g2.setColor(textColor); // 핑크색 텍스트
        FontMetrics fm = g2.getFontMetrics();
        String text = btn.getText();
        // 텍스트를 버튼 정중앙에 배치
        int tx = (w - fm.stringWidth(text)) / 2;
        int ty = (h - fm.getHeight()) / 2 + fm.getAscent();
        // 클릭 시 텍스트를 1px 아래로 내려 눌리는 느낌 연출
        if (pressed) ty += 1;
        g2.drawString(text, tx, ty);

        g2.dispose();
    }

    @Override
    public Dimension getPreferredSize(JComponent c) {
        // 버튼 기본 크기 지정
        return new Dimension(68, 48);
    }
}


