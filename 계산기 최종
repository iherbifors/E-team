        pack();
        setLocationRelativeTo(null);
    }

    // ── 숫자 입력 처리 ───────────────────────────────────────
    // 결과가 표시된 상태에서 숫자를 누르면 수식 초기화 후 새로 시작
    // 연산자를 누른 후 숫자를 누르면 이어서 입력됨
    private void appendDigit(String digit) {
        if (resultShown) {
            // 결과 표시 후 숫자 입력 → 새 수식 시작
            exp = "";
            resultShown = false;
        }
        exp += digit;
        textField.setText(exp);
    }

    // ── 연산자 / 기호 입력 처리 ──────────────────────────────
    // resultShown 을 false 로만 바꾸고 수식에 이어 붙임
    // (결과값 뒤에 연산자를 누르면 이어서 계산 가능: 예) 결과 6 → '+3' 입력)
    private void appendToExp(String token) {
        resultShown = false;
        exp += token;
        textField.setText(exp);
    }

    // ── C 버튼: 전체 초기화 ──────────────────────────────────
    private void clearExp() {
        resultShown = false;
        exp = "";
        textField.setText("0"); // 디스플레이를 0으로 리셋
    }

    // ── = 버튼: 계산 실행 ────────────────────────────────────
    private void calculate() {
        try {
            // 1단계: 중위 표현식 → 후위 표현식 변환
            String postfix = Infix2Postfix.convert(exp);
            // 2단계: 후위 표현식 계산
            double result  = Calc.eval(postfix);

            // 정수 결과면 소수점 없이 표시 (예: 6.0 → 6)
            if (result == Math.floor(result) && !Double.isInfinite(result))
                textField.setText(String.valueOf((long) result));
            else
                textField.setText(String.valueOf(result));

            exp = textField.getText(); // 결과값을 exp 에 저장 → 이어서 연산 가능
            resultShown = true;        // 결과 표시 상태로 전환

        } catch (ArithmeticException ae) {
            // 0으로 나누기 등 산술 오류
            textField.setText("오류: " + ae.getMessage());
            exp = "";
            resultShown = false;
        } catch (Exception ex) {
            // 수식 형식이 잘못된 경우
            textField.setText("수식을 입력하세요.");
            exp = "";
            resultShown = false;
        }
    }

    // ── 버튼 생성 팩토리 메서드 ──────────────────────────────
    // 반복되는 버튼 생성 코드를 하나로 통일
    // label: 버튼에 표시할 텍스트
    // bg: 버튼 배경색
    // listener: 클릭 시 실행할 동작
    private JButton makeButton(String label, Color bg, ActionListener listener) {
        JButton btn = new JButton(label);
        btn.setFont(FONT_BTN);
        // 커스텀 둥근 버튼 UI 적용 (배경색 + 핑크 텍스트)
        btn.setUI(new RoundButtonUI(bg, COLOR_TEXT_BTN));
        btn.setMargin(new Insets(0, 0, 0, 0)); // 내부 여백 제거 (UI에서 직접 처리)
        btn.addActionListener(listener);
        return btn;
    }

    // ── 기존 코드 호환 getter ────────────────────────────────
    public JTextField getTextField()      { return textField; }
    public JButton    getBtnNewButton_1() { return btnNewButton_1; }
